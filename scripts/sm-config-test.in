#!/bin/sh

CONFIG_FILE="${1:-/usr/local/etc/solar-monitor.conf}"

REQUIRED_KEYS="
station.callsign
station.name
station.timezone
hardware.sdr_device
hardware.sdr_model
hardware.antenna
capture.driver
capture.frequency_start_mhz
capture.frequency_end_mhz
capture.bin_size_khz
capture.interval_seconds
capture.duration_minutes
capture.gain
paths.raw_dir
paths.processed_dir
paths.index_dir
paths.publish_dir
paths.bbs_dir
paths.log_file
processing.enabled
index.enabled
index.name
publishing.web_enabled
publishing.bbs_enabled
"

get_config() {
    section="$1"
    key="$2"

    awk -F= -v section="[$section]" -v key="$key" '
        $0 == section {
            in_section = 1
            next
        }

        /^\[/ {
            in_section = 0
        }

        in_section {
            lhs = $1
            rhs = $0
            sub(/^[^=]*=/, "", rhs)

            gsub(/^[ \t]+|[ \t]+$/, "", lhs)
            gsub(/^[ \t]+|[ \t]+$/, "", rhs)

            if (lhs == key) {
                print rhs
                exit
            }
        }
    ' "$CONFIG_FILE"
}

echo "solar-monitor config test"
echo "========================="
echo

if [ ! -f "$CONFIG_FILE" ]; then
    echo "FAIL: config file not found: $CONFIG_FILE"
    exit 1
fi

echo "OK: config file found: $CONFIG_FILE"
echo

FAILURES=0

for item in $REQUIRED_KEYS; do
    section="${item%%.*}"
    key="${item#*.}"
    value="$(get_config "$section" "$key")"

    if [ -z "$value" ]; then
        echo "FAIL: missing or empty [$section] $key"
        FAILURES=$((FAILURES + 1))
    else
        echo "OK: [$section] $key = $value"
    fi
done

echo

if [ "$FAILURES" -ne 0 ]; then
    echo "Config test failed: $FAILURES missing or empty required value(s)."
    exit 1
fi

echo "Config test passed."
exit 0
